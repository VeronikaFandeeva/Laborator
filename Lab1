def binary_subtract(a, b):
    # Проверяю на положительность чисел
    if a <= 0 or b <= 0:
        raise ValueError("Оба числа должны быть больше нуля")
    
    # Проверяю, что первое число больше второго
    if a < b:
        raise ValueError("Первое число должно быть больше второго")

    low = 0
    high = a  # Максимальное значение для разности

    while low < high:
        mid = (low + high) // 2  # Нахожу середину

        # Проверяем, если mid + b меньше a
        if mid + b < a:
            low = mid + 1  # Ищем в правой половине
        else:
            high = mid  # Ищем в левой половине

    return low - 1  # Возвращаем результат
